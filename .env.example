# Application Settings
APP__APP_NAME=FastAPI Production Template
APP__APP_VERSION=0.1.0
APP__APP_DESCRIPTION=Production-ready FastAPI template with best practices
APP__ENVIRONMENT=development
APP__DEBUG=True
APP__API_V1_PREFIX=/api/v1

# Server Settings
SERVER__HOST=0.0.0.0
SERVER__PORT=8000
SERVER__WORKERS=4
SERVER__RELOAD=True

# Database Settings
DATABASE__DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fastapi_db
DATABASE__DATABASE_POOL_SIZE=20
DATABASE__DATABASE_MAX_OVERFLOW=0
DATABASE__DATABASE_ECHO=False

# Database Docker Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fastapi_db
HOST_POSTGRES_PORT=5432

# Redis Settings
REDIS__REDIS_URL=redis://localhost:6379/0
REDIS__REDIS_CACHE_TTL=3600
HOST_REDIS_PORT=6379

# Application Docker Settings
HOST_APP_PORT=8000

# Security Settings
SECURITY__SECRET_KEY=your-secret-key-here-change-in-production
SECURITY__ALGORITHM=HS256
SECURITY__ACCESS_TOKEN_EXPIRE_MINUTES=30
SECURITY__REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Settings
CORS__CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
CORS__CORS_ALLOW_CREDENTIALS=True
CORS__CORS_ALLOW_METHODS=["*"]
CORS__CORS_ALLOW_HEADERS=["*"]

# Logging Settings
LOGGING__LOG_LEVEL=INFO
LOGGING__LOG_FORMAT=<green>{time:YYYY-MM-DD HH:mm:ss.SSS}</green> | <level>{level: <8}</level> | <cyan>{name}</cyan>:<cyan>{function}</cyan>:<cyan>{line}</cyan> - <level>{message}</level>
LOGGING__LOG_ROTATION=100 MB
LOGGING__LOG_RETENTION=30 days
LOGGING__LOG_COMPRESSION=zip

# Email Settings (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@example.com
EMAILS_FROM_NAME=FastAPI Template

# Celery Settings (Optional)
CELERY__CELERY_BROKER_URL=redis://localhost:6379/1
CELERY__CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Rate Limiting (Optional)
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# Monitoring (Optional)
SENTRY_DSN=
